# AI SEO Platform Configuration
# All API keys are optional - the tool works with whatever keys you provide.

# LLM Provider Keys (BYOK - Bring Your Own Key)
AISEO_OPENAI_API_KEY=
AISEO_ANTHROPIC_API_KEY=
AISEO_GOOGLE_API_KEY=
AISEO_PERPLEXITY_API_KEY=

# Search Volume Keys (all optional)
AISEO_GOOGLE_ADS_DEVELOPER_TOKEN=
AISEO_GOOGLE_ADS_CLIENT_ID=
AISEO_SEMRUSH_API_KEY=
AISEO_AHREFS_API_KEY=

# Infrastructure
AISEO_DATABASE_URL=sqlite:///aiseo.db
AISEO_REDIS_URL=redis://localhost:6379/0

# Scan defaults
AISEO_DEFAULT_QUERY_COUNT=50
AISEO_MAX_QUERIES_PER_SCAN=200
AISEO_SCAN_TIMEOUT_SECONDS=300
